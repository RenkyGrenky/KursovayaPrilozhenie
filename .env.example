# ============================================================
# NN MinObr AI — единый конфиг (используется docker-compose)
# Скопируйте в .env и заполните значения:  copy .env.example .env
# ============================================================

# ---------- Общие ----------
APP_ENV=production
APP_NAME=NN MinObr AI
APP_VERSION=1.0.0

# ---------- Безопасность (ОБЯЗАТЕЛЬНО ЗАМЕНИТЕ) ----------
SECRET_KEY=change-me-generate-random-64-chars
JWT_SECRET_KEY=change-me-generate-random-64-chars

# ---------- PostgreSQL ----------
POSTGRES_DB=nn_minobr_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@db:5432/nn_minobr_ai

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- Backend ----------
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost","http://localhost:3000","http://localhost:5173","http://127.0.0.1:5173"]

# ---------- AI (OpenRouter) ----------
# Оставьте пустым, чтобы отключить AI-функции.
# Ключ НЕ коммитьте в репозиторий.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---------- Frontend ----------
REACT_APP_API_URL=/api/v1
REACT_APP_APP_NAME=Министерство образования Нижегородской области
VITE_API_URL=/api/v1
